# Environment Configuration for RAG Pipeline

# Vector Database Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

MILVUS_HOST=localhost
MILVUS_PORT=19530

# LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Hugging Face
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# OpenAI (if using OpenAI models)
OPENAI_API_KEY=your_openai_api_key_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/rag_pipeline.log

# Data Paths
DATA_DIR=data/
RESULTS_DIR=results/
MODELS_DIR=models/

# Indexing Configuration
BATCH_SIZE=32
CHUNK_SIZE=512
OVERLAP=50

# Retrieval Configuration
TOP_K=5
SIMILARITY_THRESHOLD=0.5

# Reranking
USE_RERANKER=true
RERANKER_MODEL=monot5

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# Ray/Distributed Processing
USE_RAY=false
RAY_WORKERS=4

# Experiment Tracking
USE_WANDB=false
WANDB_PROJECT=rag-pipeline
